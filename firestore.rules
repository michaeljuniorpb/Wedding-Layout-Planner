rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: layouts
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - Owner of the layout
    //   - name: string (required) - Name of the layout
    //   - elements: list (required) - Array of LayoutElement objects
    //   - venueDimensions: map (required) - { width: number, height: number }
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidLayout(data) {
      return data.userId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.elements is list && data.elements.size() < 1000 &&
             data.venueDimensions is map &&
             data.venueDimensions.width is number && data.venueDimensions.width > 0 &&
             data.venueDimensions.height is number && data.venueDimensions.height > 0;
    }

    match /layouts/{layoutId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidLayout(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.userId == resource.data.userId &&
                      isValidLayout(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
